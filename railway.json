{
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "pip install -r backend/requirements.txt"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd backend && gunicorn --bind 0.0.0.0:5000 app:app"
  }
}
